# Auto-detect text files and normalize line endings
* text=auto

# Unity YAML files — force LF to reduce merge conflicts
*.unity text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.asset text eol=lf merge=unityyamlmerge
*.meta text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.mat text eol=lf
*.overrideController text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf

# Source files
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Binary assets — never diff or merge
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.tif binary
*.tiff binary
*.hdr binary
*.exr binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.mov binary
*.fbx binary
*.obj binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.unitypackage binary
